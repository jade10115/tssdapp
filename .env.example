APP_NAME=Laravel
APP_ENV=production
APP_DEBUG=false
APP_URL=${APP_URL}

LOG_CHANNEL=stack

DB_CONNECTION=mysql
DB_HOST=${MYSQLHOST}
DB_PORT=${MYSQLPORT}
DB_DATABASE=${MYSQLDATABASE}
DB_USERNAME=${MYSQLUSER}
DB_PASSWORD=${MYSQLPASSWORD}

SESSION_DRIVER=cookie
SESSION_DOMAIN=.railway.app

SANCTUM_STATEFUL_DOMAINS=${RAILWAY_PUBLIC_DOMAIN}